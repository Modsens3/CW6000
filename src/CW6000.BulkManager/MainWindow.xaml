<Window x:Class="CW6000.BulkManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CW6000 Bulk Media Manager" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="EPSON CW-C6000Ae Bulk Media Manager" FontSize="24" FontWeight="Bold"/>
            <TextBlock Margin="0,6,0,12" Text="Φόρτωση CSV, έλεγχος διαστάσεων και μαζική δημιουργία Media Definitions μέσω Windows UI Automation."/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="CsvPathText" Grid.Column="0" Height="34" VerticalContentAlignment="Center" IsReadOnly="True"/>
            <Button Grid.Column="1" Margin="8,0,0,0" Padding="18,6" Content="Browse CSV" Click="Browse_Click"/>
            <Button Grid.Column="2" Margin="8,0,0,0" Padding="18,6" Content="Test 1 Preset" Click="Test_Click"/>
            <Button Grid.Column="3" Margin="8,0,0,0" Padding="18,6" Content="Create All" Click="CreateAll_Click"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="PresetsGrid" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="45"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Width mm" Binding="{Binding WidthMm}" Width="90"/>
                    <DataGridTextColumn Header="Length mm" Binding="{Binding LengthMm}" Width="90"/>
                    <DataGridTextColumn Header="Width in" Binding="{Binding WidthIn}" Width="85"/>
                    <DataGridTextColumn Header="Length in" Binding="{Binding LengthIn}" Width="85"/>
                    <DataGridCheckBoxColumn Header="Rotate" Binding="{Binding Rotated}" Width="65"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                <GroupBox Header="Default Settings" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Text="Gap (inch)" Margin="0,5"/>
                        <TextBox x:Name="GapText" Grid.Row="0" Grid.Column="1" Text="0.12" Margin="0,3"/>
                        <TextBlock Grid.Row="1" Text="Side Gap (inch)" Margin="0,5"/>
                        <TextBox x:Name="SideGapText" Grid.Row="1" Grid.Column="1" Text="0.08" Margin="0,3"/>
                        <TextBlock Grid.Row="2" Text="Media Form" Margin="0,5"/>
                        <ComboBox x:Name="MediaFormCombo" Grid.Row="2" Grid.Column="1" SelectedIndex="0" Margin="0,3">
                            <ComboBoxItem Content="Die-cut Label (Gap)"/>
                            <ComboBoxItem Content="Die-cut Label (BlackMark)"/>
                            <ComboBoxItem Content="Continuous Label"/>
                        </ComboBox>
                        <TextBlock Grid.Row="3" Text="Coating" Margin="0,5"/>
                        <ComboBox x:Name="CoatingCombo" Grid.Row="3" Grid.Column="1" SelectedIndex="6" Margin="0,3">
                            <ComboBoxItem Content="Plain Paper"/><ComboBoxItem Content="Matte Paper"/><ComboBoxItem Content="Synthetic"/>
                            <ComboBoxItem Content="Texture Paper"/><ComboBoxItem Content="Glossy Paper"/><ComboBoxItem Content="Glossy Film"/>
                            <ComboBoxItem Content="High Glossy Paper"/>
                        </ComboBox>
                        <TextBlock Grid.Row="4" Text="Print Quality" Margin="0,5"/>
                        <ComboBox x:Name="QualityCombo" Grid.Row="4" Grid.Column="1" SelectedIndex="3" Margin="0,3">
                            <ComboBoxItem Content="Max Speed"/><ComboBoxItem Content="Speed"/><ComboBoxItem Content="Normal"/><ComboBoxItem Content="Quality"/>
                        </ComboBox>
                    </Grid>
                </GroupBox>

                <Button Margin="0,14,0,0" Padding="12,8" Content="Stop" Click="Stop_Click"/>
                <ProgressBar x:Name="Progress" Height="22" Margin="0,14,0,0" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="StatusText" Margin="0,10,0,0" Text="Ready." TextWrapping="Wrap"/>
                <TextBox x:Name="LogText" Margin="0,12,0,0" Height="260" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="3" Margin="0,12,0,0" Foreground="DarkRed" Text="Πριν την εκτέλεση: άνοιξε Printing Preferences → Media Definition και άφησε το παράθυρο ανοικτό."/>
    </Grid>
</Window>
